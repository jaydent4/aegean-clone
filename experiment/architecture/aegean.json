{
  "services": {
    "client": {
      "type": "client",
      "next": ["node2", "node3", "node4"],
      "client_workflow": "aegean_pipelined"
    },
    "oha_client": {
      "type": "oha_client",
      "next": ["node2", "node3", "node4"],
      "client_workflow": "aegean_oha_client"
    },
    "middle": {
      "type": "server",
      "clients": ["node1"],
      "nodes": ["node2", "node3", "node4"],
      "exec_workflow": "aegean_middle",
      "init_state_workflow": "aegean_default",
      "shimQuorumSize": 1,
      "verifyResponseQuorumSize": 1,
      "execVerifyQuorumSize": 2,
      "phaseQuorumSize": 2,
      "expectedExecVotes": 3
    },
    "backend": {
      "type": "server",
      "clients": ["node2", "node3", "node4"],
      "nodes": ["node5", "node6", "node7"],
      "exec_workflow": "aegean_backend_diverge_2",
      "init_state_workflow": "aegean_default",
      "shimQuorumSize": 2,
      "verifyResponseQuorumSize": 1,
      "execVerifyQuorumSize": 2,
      "phaseQuorumSize": 2,
      "expectedExecVotes": 3
    }
  },
  "nodes": {
    "node1": {
      "service": "oha_client"
    },
    "node2": {
      "service": "middle",
      "is_primary_batcher": true
    },
    "node3": {
      "service": "middle",
      "is_primary_batcher": false
    },
    "node4": {
      "service": "middle",
      "is_primary_batcher": false
    },
    "node5": {
      "service": "backend",
      "is_primary_batcher": true
    },
    "node6": {
      "service": "backend",
      "is_primary_batcher": false
    },
    "node7": {
      "service": "backend",
      "is_primary_batcher": false
    }
  }
}
